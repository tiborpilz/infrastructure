# SigNoz oauth2-proxy OIDC secret — TEMPLATE (plaintext, NOT applied).
#
# This sandbox has no sops binary or private age key, so the encrypted file
# could not be generated here. To finish wiring SigNoz SSO:
#
#   1. Generate the values:
#        client-id:      signoz
#        client-secret:  openssl rand -hex 32
#        cookie-secret:  openssl rand -base64 32
#      Fill them into the stringData block below.
#   2. Encrypt to secrets-signoz.enc.yaml (uses recipients from ../../../.sops.yaml):
#        sops --encrypt --input-type yaml --output-type yaml \
#          secrets-signoz.enc.yaml.example > secrets-signoz.enc.yaml
#      (If the PGP recipient is unreachable, encrypt to the age recipients only
#       and run `sops updatekeys secrets-signoz.enc.yaml` later — see README.)
#   3. Uncomment `- secrets-signoz.enc.yaml` in kustomization.yaml.
#   4. Delete this .example file.
#
# The same `client-secret` key is consumed by BOTH oauth2-proxy (existingSecret)
# and Authentik (SIGNOZ_OIDC_CLIENT_SECRET env in identity/authentik/argo-app.yaml),
# so setting it once here keeps both sides in sync.
apiVersion: isindir.github.com/v1alpha3
kind: SopsSecret
metadata:
  name: signoz-secrets
  namespace: observability
spec:
  secretTemplates:
    - name: signoz-oauth2-proxy-secrets
      annotations:
        reflector.v1.k8s.emberstack.com/reflection-allowed: "true"
        reflector.v1.k8s.emberstack.com/reflection-allowed-namespaces: authentik
        reflector.v1.k8s.emberstack.com/reflection-auto-enabled: "true"
        reflector.v1.k8s.emberstack.com/reflection-auto-namespaces: authentik
      stringData:
        client-id: signoz
        client-secret: REPLACE_WITH_openssl_rand_hex_32
        cookie-secret: REPLACE_WITH_openssl_rand_base64_32
