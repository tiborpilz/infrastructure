# Woodpecker server<->agent shared secret. The Forgejo OAuth client used for
# login is NOT stored here — applications/services/woodpecker/oauth-bootstrap.yaml
# creates it against the Forgejo API at deploy time.
apiVersion: isindir.github.com/v1alpha3
kind: SopsSecret
metadata:
  name: woodpecker-secrets
  namespace: woodpecker
spec:
  secretTemplates:
    - name: woodpecker-secrets
      stringData:
        # openssl rand -hex 32
        WOODPECKER_AGENT_SECRET: CHANGEME
