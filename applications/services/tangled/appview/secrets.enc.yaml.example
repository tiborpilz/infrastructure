# Copy to secrets.enc.yaml, fill in real values, then encrypt in place:
#
#   cp secrets.enc.yaml.example secrets.enc.yaml
#   $EDITOR secrets.enc.yaml
#   sops -e -i secrets.enc.yaml
#
# See README.md for how to generate each value.
apiVersion: v1
kind: Secret
metadata:
  name: appview-secrets
  namespace: tangled
type: Opaque
stringData:
  # 32 characters, e.g. `openssl rand -hex 16`
  TANGLED_COOKIE_SECRET: CHANGEME000000000000000000000000
  # P-256 private key in multibase syntax ("z42..."), generated with
  # `goat key generate -t P-256` (see README)
  TANGLED_OAUTH_CLIENT_SECRET: z42CHANGEME
  # any stable identifier for the key above, e.g. `date +%s`
  TANGLED_OAUTH_CLIENT_KID: "1751500000"
