# oauth2-proxy credentials for Headlamp. Decrypted at render time by ksops;
# reflected into the authentik namespace so the blueprint's
# !Env HEADLAMP_OIDC_CLIENT_SECRET resolves (see kustomization.yaml patches).
apiVersion: v1
kind: Secret
metadata:
  name: headlamp-oauth2-proxy-secrets
  namespace: headlamp
type: Opaque
stringData:
  # must match client_id in blueprints/oidc.yaml
  client-id: headlamp
  # openssl rand -base64 48
  client-secret: CHANGEME
  # oauth2-proxy cookie secret, exactly 32 bytes:
  # openssl rand -base64 32 | head -c 32
  cookie-secret: CHANGEME
