# Harbor internal secrets. Generation hints per key; see
# https://goharbor.io/docs and the harbor chart's values for semantics.
apiVersion: isindir.github.com/v1alpha3
kind: SopsSecret
metadata:
  name: harbor-secrets
  namespace: harbor
spec:
  secretTemplates:
    - name: harbor-admin
      stringData:
        HARBOR_ADMIN_PASSWORD: CHANGEME
    - name: harbor-core
      stringData:
        # openssl rand -hex 8  (16 chars)
        secret: CHANGEME
        # openssl rand -base64 32
        CSRF_KEY: CHANGEME
    - name: harbor-jobservice
      stringData:
        # openssl rand -hex 8
        JOBSERVICE_SECRET: CHANGEME
    - name: harbor-registry
      stringData:
        # openssl rand -hex 8
        REGISTRY_HTTP_SECRET: CHANGEME
        # password for the internal registry user, plus its htpasswd form:
        # htpasswd -nbB harbor_registry_user '<REGISTRY_PASSWD>'
        REGISTRY_PASSWD: CHANGEME
        REGISTRY_HTPASSWD: CHANGEME
    - name: harbor-encryption
      stringData:
        # exactly 16 characters: openssl rand -hex 8
        secretKey: CHANGEME
    - name: harbor-oidc
      stringData:
        # key = OIDC client id (see blueprints/oidc.yaml)
        key: harbor
        # must equal HARBOR_OIDC_CLIENT_SECRET in
        # applications/identity/authentik/oidc-clients.enc.yaml
        secret: CHANGEME
