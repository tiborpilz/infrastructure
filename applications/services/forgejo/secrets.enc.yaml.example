# Forgejo admin bootstrap credentials and (namespace-local) OIDC client copy.
#
# NOTE: forgejo-oidc is also defined in
# applications/identity/authentik/secrets.enc.yaml (reflected into this
# namespace). Keep both in sync — consolidating them is an open TODO
# (docs/secrets.md).
apiVersion: isindir.github.com/v1alpha3
kind: SopsSecret
metadata:
  name: forgejo-secrets
  namespace: forgejo
spec:
  secretTemplates:
    - name: forgejo-admin
      stringData:
        username: CHANGEME
        password: CHANGEME
    - name: forgejo-oidc
      stringData:
        # key = OIDC client id (see blueprints/oidc.yaml)
        key: forgejo
        # must equal the `secret` in applications/identity/authentik/secrets.enc.yaml
        secret: CHANGEME
