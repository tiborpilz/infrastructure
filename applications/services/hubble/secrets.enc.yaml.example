# oauth2-proxy credentials for the Hubble UI. Decrypted at render time by
# ksops; reflected into the authentik namespace so the blueprint's
# !Env HUBBLE_OIDC_CLIENT_SECRET resolves.
#
# (The currently committed secrets.enc.yaml predates the data/stringData-only
# encryption rule and is encrypted wholesale; recreating it from this example
# yields the normal format.)
apiVersion: v1
kind: Secret
metadata:
  name: oauth2-proxy-secrets
  namespace: hubble
type: Opaque
stringData:
  # must match client_id in blueprints/oidc.yaml
  client-id: hubble
  # openssl rand -base64 48
  client-secret: CHANGEME
  # oauth2-proxy cookie secret, exactly 32 bytes:
  # openssl rand -base64 32 | head -c 32
  cookie-secret: CHANGEME
