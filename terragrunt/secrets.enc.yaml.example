# Terragrunt-layer secrets. scripts/init-keys copies this to
# terragrunt/secrets.enc.yaml, fills in argocd_age_key, and encrypts it;
# fill the remaining CHANGEME values with `sops edit terragrunt/secrets.enc.yaml`.
#
# Every value in this file is encrypted (see .sops.yaml rule 1).

# Hetzner Cloud API token (project-scoped, read/write).
hcloud_token: CHANGEME

# Cloudflare API token with Zone:Read + DNS:Edit on the platform domain's zone.
# Used by cert-manager (DNS-01), external-dns, and the dns Terraform module.
cloudflare_api_token: CHANGEME

# Authentik server secret key: openssl rand -base64 48
authentik_secret_key: CHANGEME

# Age private key used in-cluster: mounted into the ArgoCD repo-server (ksops)
# and the sops-secrets-operator. scripts/init-keys fills this automatically
# from .keys/platform.agekey.
argocd_age_key: CHANGEME

# Passphrase for client-side OpenTofu state/plan encryption (terragrunt/root.hcl).
# Losing it means losing the state. openssl rand -base64 32
state_passphrase: CHANGEME

# Proxmox (only needed when proxmox_workers is non-empty in
# terragrunt/cluster/terragrunt.hcl — delete otherwise).
proxmox_api_token: CHANGEME
proxmox_ssh_private_key: CHANGEME
proxmox_ssh_password: CHANGEME
