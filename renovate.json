{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "argocd": {
    "managerFilePatterns": ["/applications/.*\\.ya?ml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/applications/.*\\.ya?ml$/"]
  },
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/applications/.*\\.ya?ml$/"],
      "matchStrings": ["imageName: (?<depName>[^\\s:]+):(?<currentValue>\\S+)"],
      "datasourceTemplate": "docker"
    }
  ]
}
